# NordVPN SOCKS5 Proxy (get from NordVPN dashboard → Manual Setup)
NORD_HOST=amsterdam.nl.socks.nordhold.net
NORD_PORT=1080
NORD_USER=your_nordvpn_service_username
NORD_PASS=your_nordvpn_service_password

# Chrome path (auto-detected if not set)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# CDP port for Chrome remote debugging
CDP_PORT=9222
